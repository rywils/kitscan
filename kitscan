#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEB_DIR="$ROOT_DIR/web"
BUILD_ENTRY="$WEB_DIR/build/index.js"

PORT="${PORT:-3000}"
HOST="${HOST:-127.0.0.1}"

print_help() {
	echo "kitscan - start Security Audit Scanner UI"
	echo
	echo "Usage:"
	echo "  ./kitscan [options]"
	echo
	echo "Options:"
	echo "  -p, --port <port>    Set server port (default: 3000)"
	echo "  -H, --host <host>    Set bind host (default: 127.0.0.1)"
	echo "  -h, --help           Show this help message"
	echo
	echo "Examples:"
	echo "  ./kitscan"
	echo "  ./kitscan -p 3001"
	echo "  ./kitscan -H 0.0.0.0   # LAN-accessible (use intentionally)"
	echo "  ./kitscan --port 8080"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
		-h|--help)
			print_help
			exit 0
			;;
		-p|--port)
			if [[ $# -lt 2 ]]; then
				echo "Error: --port requires a value."
				echo "Try ./kitscan --help"
				exit 1
			fi
			PORT="$2"
			shift 2
			;;
		--port=*)
			PORT="${1#*=}"
			shift
			;;
		-H|--host)
			if [[ $# -lt 2 ]]; then
				echo "Error: --host requires a value."
				echo "Try ./kitscan --help"
				exit 1
			fi
			HOST="$2"
			shift 2
			;;
		--host=*)
			HOST="${1#*=}"
			shift
			;;
		*)
			echo "Error: Unknown argument '$1'"
			echo "Try ./kitscan --help"
			exit 1
			;;
	esac
done

if ! [[ "$PORT" =~ ^[0-9]+$ ]] || (( PORT < 1 || PORT > 65535 )); then
	echo "Error: Invalid port '$PORT'. Must be a number between 1 and 65535."
	exit 1
fi

if [[ -z "$HOST" ]]; then
	echo "Error: Invalid host value."
	exit 1
fi

if [[ ! -d "$WEB_DIR" ]]; then
	echo "Error: web directory not found at: $WEB_DIR"
	exit 1
fi

if [[ ! -d "$WEB_DIR/node_modules" ]]; then
	echo "Dependencies are missing."
	echo "Run ./install first."
	exit 1
fi

if [[ ! -f "$BUILD_ENTRY" ]]; then
	echo "Production build not found. Building now..."
	npm --prefix "$WEB_DIR" run build
fi

if command -v ss >/dev/null 2>&1 && ss -ltn "( sport = :$PORT )" | rg -q ":$PORT"; then
	echo "Port $PORT is already in use."
	echo "Try: ./kitscan -p 3001"
	exit 1
fi

echo "Your Web UI is accessible at: http://$HOST:$PORT"
exec env PORT="$PORT" HOST="$HOST" node "$BUILD_ENTRY"
